{
  "name": "@realtyodyssey/supabase",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "supabase:cli": "npx supabase --workdir ..",
    "supabase:start": "npx supabase --workdir .. start",
    "supabase:status": "npx supabase --workdir .. status",
    "supabase:db:reset": "npx supabase --workdir .. db reset --local",
    "supabase:stop": "npx supabase --workdir .. stop",
    "typecheck": "tsc --noEmit",
    "functions:fmt:check": "deno fmt --check functions",
    "functions:lint": "deno lint functions",
    "functions:check": "deno check functions/mpesa-create-setup/index.ts functions/mpesa-register-c2b/index.ts functions/daraja-c2b-validation/index.ts functions/daraja-c2b-confirmation/index.ts"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.7"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "5.9.2"
  }
}
